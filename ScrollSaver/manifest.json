{
  "manifest_version": 3,
  "name": "Scroll Saver",
  "description": "Save and jump back to scroll positions on any web page or PDF.",
  "permissions": ["storage", "tabs", "scripting", "activeTab"],
  "host_permissions": ["*://*/*", "file://*/*"],
  "web_accessible_resources": [
    {
      "resources": ["pdfjs/*", "output.css"],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "commands": {
    "create-bookmark": {
      "suggested_key": {
        "default": "Ctrl+Shift+B",
        "mac": "Command+Shift+B"
      },
      "description": "Creates a bookmark on the current page"
    },
    "next-bookmark": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Navigates to the next bookmark on the current page"
    },
    "previous-bookmark": {
      "suggested_key": {
        "default": "Ctrl+Shift+J",
        "mac": "Command+Shift+J"
      },
      "description": "Navigates to the previous bookmark on the current page"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "exclude_globs": ["*.pdf", "*.pdf?*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "version": "1.1",
  "action": {
    "default_popup": "scrollsaver.html"
  }
  
}